# =============================================================================
# Adhoc Plattform — apps/web
# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# .env.local ist gitignoriert.
# =============================================================================

# --- Datenquelle ---------------------------------------------------------------
# "db" für Supabase/Postgres, "fixtures" für lokale JSON-Stubs.
APP_DATA_SOURCE=db
DATABASE_URL=postgres://user:pass@host:6543/postgres?sslmode=require
PG_POOL_MAX=4
PG_CONNECTION_TIMEOUT_MS=5000
PG_IDLE_TIMEOUT_MS=10000

# --- Admin-Authentifizierung (PFLICHT) -----------------------------------------
# Supabase-Projekt mit Email/Password-Auth. Der User wird einmalig im
# Supabase-Dashboard angelegt. Nur Emails in ADMIN_EMAILS dürfen den
# Admin-Bereich betreten — alles andere wird via Middleware geblockt.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
ADMIN_EMAILS=admin@example.com

# --- Mobilithek (mTLS-Pull + Webhook-Forwarding) -------------------------------
MOBILITHEK_BASE_URL=https://m2m.mobilithek.info
MOBILITHEK_CERT_P12_PATH=/abs/path/to/certs/mobilithek.p12
MOBILITHEK_USER_AGENT=adhoc-plattform/1.0
MOBILITHEK_TIMEOUT_MS=30000
# Pflicht: shared Secret zwischen Edge-Function und /api/internal/mobilithek/webhook
MOBILITHEK_FORWARD_SECRET=change-me-strong-random

# --- Geocoding / Routing -------------------------------------------------------
OSM_GEOCODER_USER_AGENT=adhoc-plattform/1.0 (contact@example.com)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org
VALHALLA_URL=https://valhalla1.openstreetmap.de

# --- Map-Tiles (öffentlich, an Browser ausgeliefert) ---------------------------
NEXT_PUBLIC_MAP_TILE_URL=
NEXT_PUBLIC_MAP_STYLE=
NEXT_PUBLIC_MAP_STYLE_LIGHT=
NEXT_PUBLIC_MAP_STYLE_DARK=
NEXT_PUBLIC_MAP_STYLE_COLOR=
NEXT_PUBLIC_MAP_STATIONS_URL=

# --- Tuning / Limits (alles optional) ------------------------------------------
ADMIN_FEEDS_TIMEOUT_MS=4000
ADMIN_STATIONS_TIMEOUT_MS=4000
ADMIN_SYNC_RUNS_TIMEOUT_MS=4000
ADMIN_INITIAL_LOAD_TIMEOUT_MS=4000
FEED_CYCLE_CONCURRENCY=2
FEED_CYCLE_QUEUE_LIMIT=8
FEED_RUN_TIMEOUT_MS=90000
INGEST_LOCK_TIMEOUT=5s
INGEST_STATEMENT_TIMEOUT=60s
INGEST_IDLE_IN_TRANSACTION_TIMEOUT=30s
INGEST_HISTORY_CLEANUP=true
INGEST_HISTORY_CLEANUP_LIMIT=2000
SYNC_RUN_STALE_AFTER=15min
RAW_FEED_PAYLOAD_RETENTION_DAYS=14
RAW_PAYLOAD_MAX_BYTES=524288
SNAPSHOT_RETENTION_DAYS=30
MAP_TILE_DB_CONCURRENCY=2
MAP_TILE_SLOT_WAIT_TIMEOUT_MS=2000
ROUTE_CANDIDATE_DB_TIMEOUT_MS=4000

# Nur lokal/CI: deaktiviert echten Mobilithek-Pull, nutzt db/fixtures/*.json
# MOBILITHEK_USE_FIXTURES=1
